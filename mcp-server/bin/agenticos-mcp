#!/bin/sh
set -eu

script=$0
while [ -L "$script" ]; do
  link=$(readlink "$script")
  case "$link" in
    /*) script=$link ;;
    *) script=$(dirname "$script")/$link ;;
  esac
done

script_dir=$(CDPATH= cd "$(dirname "$script")" && pwd -P)
package_dir=$(CDPATH= cd "$script_dir/.." && pwd -P)

exec node "$package_dir/build/index.js" "$@"
